# Public site URL (no trailing slash). Used for Open Graph and password-reset redirect links.
# In Supabase Dashboard → Authentication → URL configuration, add:
#   https://YOUR_DOMAIN/reset-password
#   http://localhost:5173/reset-password (dev)
# Example: https://tu-app.vercel.app
VITE_SITE_URL=

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Cloudinary (event wall photos/videos). Create an unsigned upload preset in Cloudinary Dashboard.
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset-name
